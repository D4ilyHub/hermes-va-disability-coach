    {
      "aliases": [
        "back strain",
        "neck strain",
        "lumbosacral strain",
        "cervical strain"
      ],
      "automatable": "partial",
      "body_system": "musculoskeletal",
      "criteria": [
        {
          "criteria_text": "Unfavorable ankylosis of the entire spine.",
          "judgment": "medical",
          "manual_review_required": false,
          "percent": 100,
          "requirements": [
            {
              "fact": "spine.unfavorable_ankylosis_entire",
              "operator": "eq",
              "value": true
            }
          ]
        },
        {
          "criteria_text": "Unfavorable ankylosis of the entire thoracolumbar spine.",
          "judgment": "medical",
          "manual_review_required": false,
          "percent": 50,
          "requirements": [
            {
              "fact": "spine.unfavorable_ankylosis_thoracolumbar",
              "operator": "eq",
              "value": true
            }
          ]
        },
        {
          "criteria_text": "Thoracolumbar forward flexion 30 degrees or less, or favorable ankylosis of the entire thoracolumbar spine.",
          "judgment": "medical",
          "manual_review_required": false,
          "percent": 40,
          "requirements": [
            {
              "fact": "spine.thoracolumbar_flexion_degrees",
              "operator": "<=",
              "value": 30
            }
          ]
        },
        {
          "criteria_text": "Cervical forward flexion 15 degrees or less, or favorable ankylosis of the entire cervical spine.",
          "judgment": "medical",
          "manual_review_required": false,
          "percent": 30,
          "requirements": [
            {
              "fact": "spine.cervical_flexion_degrees",
              "operator": "<=",
              "value": 15
            }
          ]
        },
        {
          "criteria_text": "Thoracolumbar forward flexion greater than 30 but not greater than 60 degrees; cervical forward flexion greater than 15 but not greater than 30; or qualifying combined motion/guarding findings.",
          "judgment": "medical",
          "manual_review_required": true,
          "percent": 20,
          "requirements": []
        },
        {
          "criteria_text": "Qualifying lesser range-of-motion, tenderness, spasm, guarding, or vertebral fracture findings.",
          "judgment": "medical",
          "manual_review_required": true,
          "percent": 10,
          "requirements": []
        }
      ],
      "diagnostic_code": "5237",
      "laterality_matters": false,
      "notes": [
        "Measurements must account for valid examination, pain, repeated use, and flare-ups under current law. Evaluate associated objective neurologic abnormalities separately only when warranted."
      ],
      "section": "4.71a",
      "separate_issue_flags": [],
