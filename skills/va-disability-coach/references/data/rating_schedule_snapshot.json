      "automatable": "qualitative",
      "body_system": "neurologic",
      "criteria": [
        {
          "criteria_text": "Very frequent completely prostrating and prolonged attacks productive of severe economic inadaptability.",
          "judgment": "adjudicative",
          "manual_review_required": true,
          "percent": 50,
          "requirements": []
        },
        {
          "criteria_text": "Characteristic prostrating attacks occurring on average once a month over the last several months.",
          "judgment": "adjudicative",
          "manual_review_required": true,
          "percent": 30,
          "requirements": [
            {
              "fact": "migraine.prostrating_attacks_per_month",
              "operator": ">=",
              "value": 1
            }
          ]
        },
        {
          "criteria_text": "Characteristic prostrating attacks averaging one in two months over the last several months.",
          "judgment": "adjudicative",
          "manual_review_required": true,
          "percent": 10,
          "requirements": [
            {
              "fact": "migraine.prostrating_attacks_per_two_months",
              "operator": ">=",
              "value": 1
            }
          ]
        },
        {
          "criteria_text": "Less frequent attacks.",
          "judgment": "adjudicative",
          "manual_review_required": true,
          "percent": 0,
          "requirements": []
        }
